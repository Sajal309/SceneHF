# Planner Configuration
PLANNER_PROVIDER=gemini
# Options: gemini, openai

# Google Cloud / Vertex AI
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/credentials.json
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1

# OpenAI (if using OpenAI planner)
OPENAI_API_KEY=sk-your-openai-api-key

# Fal.ai Background Removal
FAL_KEY=your-fal-api-key

# Server Configuration
HOST=0.0.0.0
PORT=8000

# CORS (comma-separated list for additional explicit origins)
# Example: CORS_ALLOW_ORIGINS=https://yourname.github.io,https://app.yourdomain.com
CORS_ALLOW_ORIGINS=

# Optional regex override for dynamic origins
# Default allows localhost:* and *.github.io
# CORS_ALLOW_ORIGIN_REGEX=
